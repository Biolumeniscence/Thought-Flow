<Window x:Class="ThoughtFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Thought Flow" Height="790" MinHeight="650" Width="1280" MinWidth="1080"
        Background="#F3F0EA" FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#232323"/>
        <SolidColorBrush x:Key="MutedInk" Color="#6C6861"/>
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7"/>
        <SolidColorBrush x:Key="Line" Color="#D8D0C4"/>
        <SolidColorBrush x:Key="Accent" Color="#315B7A"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#E2EEF3"/>
        <SolidColorBrush x:Key="Warm" Color="#A95F47"/>
        <SolidColorBrush x:Key="Side" Color="#253137"/>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E9E2D8"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="SingleLineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="WorkspaceItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#F7F0E8"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="WorkspaceItem_PreviewMouseRightButtonDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Shell" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#36434A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#E6F0F4"/>
                                <Setter Property="Foreground" Value="#1E2E35"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="FileItem_PreviewMouseRightButtonDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Shell" Background="#FFFFFF" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#9FAFB8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="Shell" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="245"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Side}" Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Thought Flow" Foreground="#FFF8EC" FontSize="23" FontWeight="Bold"/>
                    <TextBlock Text="workspaces, files, message-text" Foreground="#B8C4C9" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                    <TextBlock x:Name="SaveStatusText" Text="Saved" Foreground="#B8C4C9" FontSize="12"/>
                    <TextBlock x:Name="StoragePathText" Foreground="#8FA0A7" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,14"/>
                    <StackPanel x:Name="UndoDeleteList" Margin="0,0,0,14"/>
                    <TextBlock Text="New workspace" Foreground="#B8C4C9" FontSize="12" FontWeight="SemiBold"/>
                    <Grid Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewChannelBox"
                                 Style="{StaticResource SingleLineTextBox}"
                                 MinHeight="34"
                                 KeyDown="NewChannelBox_KeyDown"/>
                        <Button Grid.Column="1" Content="+" Margin="8,0,0,0" Click="AddChannelButton_Click"/>
                    </Grid>
                </StackPanel>

                <ListBox x:Name="ChannelsList"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource WorkspaceItemStyle}"
                         SelectionChanged="ChannelsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="15"/>
                                <TextBlock Text="{Binding CountText}" FontSize="12" Opacity="0.75" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="ChannelTitle" FontSize="29" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                    <TextBlock x:Name="ChannelSubtitle" Foreground="{StaticResource MutedInk}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Duplicate msg" Style="{StaticResource GhostButton}" Width="118" Margin="0,0,8,0" Click="DuplicateButton_Click"/>
                    <Button Content="Delete workspace" Background="{StaticResource Warm}" Width="136" Click="DeleteChannelButton_Click"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Files" Foreground="{StaticResource MutedInk}" FontSize="12" FontWeight="SemiBold"/>
                            <Button Content="Delete file" DockPanel.Dock="Right" Width="92" MinHeight="28" Padding="8,4" Background="{StaticResource Warm}" Click="DeleteFileButton_Click"/>
                        </DockPanel>
                        <ListBox x:Name="FilesList"
                                 MinHeight="48"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource FileItemStyle}"
                                 SelectionChanged="FilesList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{StaticResource MutedInk}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Text="New file" Foreground="{StaticResource MutedInk}" FontSize="12" FontWeight="SemiBold"/>
                        <Grid Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewFileBox"
                                     Style="{StaticResource SingleLineTextBox}"
                                     MinHeight="34"
                                     KeyDown="NewFileBox_KeyDown"/>
                            <Button Grid.Column="1" Content="+" Margin="8,0,0,0" Click="AddFileButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SingleLineTextBox}"
                         MinHeight="38"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="1" x:Name="SearchStatsText" Foreground="{StaticResource MutedInk}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="0">
                <Grid x:Name="MessageStreamHost" MouseLeave="MessageStreamHost_MouseLeave">
                    <RichTextBox x:Name="MessageStreamBox"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="White"
                                 Foreground="{StaticResource Ink}"
                                 FontSize="15"
                                 Padding="18"
                                 VerticalScrollBarVisibility="Auto"
                                 MouseMove="MessageStreamBox_MouseMove"
                                 PreviewMouseRightButtonDown="MessageStreamBox_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="MessageStreamBox_ContextMenuOpening"
                                 MouseLeftButtonUp="MessageStreamBox_MouseLeftButtonUp">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit" Click="EditMessageContextMenuItem_Click"/>
                                <MenuItem Header="Duplicate" Click="DuplicateMessageContextMenuItem_Click"/>
                                <MenuItem Header="Copy" Click="CopyMessageContextMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Delete" Click="DeleteMessageContextMenuItem_Click"/>
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                        <FlowDocument PagePadding="0"/>
                    </RichTextBox>
                    <Button x:Name="MessageActionsButton"
                            Content="..."
                            Width="34"
                            MinHeight="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,14,0"
                            Visibility="Collapsed"
                            Style="{StaticResource GhostButton}"
                            Click="MessageActionsButton_Click"
                            ToolTip="Message actions">
                        <Button.ContextMenu>
                            <ContextMenu Opened="MessageActionsContextMenu_Opened" Closed="MessageActionsContextMenu_Closed">
                                <MenuItem Header="Edit" Click="EditHoveredMessageMenuItem_Click"/>
                                <MenuItem Header="Duplicate" Click="DuplicateHoveredMessageMenuItem_Click"/>
                                <MenuItem Header="Copy" Click="CopyHoveredMessageMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Delete" Click="DeleteHoveredMessageMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ComposerBox"
                             MinHeight="78"
                             MaxHeight="150"
                             VerticalAlignment="Stretch"
                             KeyDown="ComposerBox_KeyDown"/>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <Button Content="Send" Width="118" Click="SendButton_Click"/>
                        <TextBlock Text="Ctrl+Enter" Foreground="{StaticResource MutedInk}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1,0,0,0" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Text="Message editor" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                    <TextBlock x:Name="EditorStateText" Foreground="{StaticResource MutedInk}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="EditorHint" Grid.Row="1" Foreground="{StaticResource MutedInk}" Margin="0,6,0,18" TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <Grid>
                        <Button x:Name="MarkButton" Width="112" Style="{StaticResource GhostButton}" Click="MarkButton_Click" ToolTip="Mark selected text with the chosen color">
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="MarkColorSwatch"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="3"
                                        Background="#D8B4FE"
                                        BorderBrush="#6D28D9"
                                        BorderThickness="1"
                                        ToolTip="Choose marker color"
                                        PreviewMouseLeftButtonDown="MarkColorSwatch_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="MarkColorSwatch_PreviewMouseLeftButtonUp"/>
                                <TextBlock Grid.Column="1" Text="Mark" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Popup x:Name="MarkColorPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=MarkButton}" StaysOpen="False">
                            <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="8">
                                <WrapPanel Width="132">
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#D8B4FE" Tag="#D8B4FE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#BFDBFE" Tag="#BFDBFE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#BBF7D0" Tag="#BBF7D0" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FEF08A" Tag="#FEF08A" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FED7AA" Tag="#FED7AA" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FBCFE8" Tag="#FBCFE8" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#CFFAFE" Tag="#CFFAFE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#E5E7EB" Tag="#E5E7EB" Click="MarkColorButton_Click"/>
                                </WrapPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button Content="Clear" Width="72" Margin="8,0,0,0" Style="{StaticResource GhostButton}" Click="ClearMarkButton_Click" ToolTip="Clear selected text marker"/>
                </StackPanel>
                <RichTextBox x:Name="EditorBox"
                             Grid.Row="3"
                             FontSize="15"
                             IsEnabled="False"
                             TextChanged="EditorBox_TextChanged"
                             BorderBrush="{StaticResource Line}"
                             BorderThickness="1"
                             Padding="10"
                             Background="White"
                             Foreground="{StaticResource Ink}"
                             VerticalScrollBarVisibility="Auto">
                    <FlowDocument PagePadding="0"/>
                </RichTextBox>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Copy" Style="{StaticResource GhostButton}" Width="88" Margin="0,0,10,0" Click="CopyButton_Click"/>
                    <Button Content="Delete" Background="{StaticResource Warm}" Width="92" Margin="0,0,10,0" Click="DeleteButton_Click"/>
                    <Button Content="Save" Width="104" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
