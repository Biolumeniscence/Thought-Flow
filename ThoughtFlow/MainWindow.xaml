<Window x:Class="ThoughtFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Thought Flow" Icon="Assets/ThoughtFlowIcon.ico"
        Height="900" MinHeight="650" Width="1400" MinWidth="1080"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}" FontFamily="Segoe UI"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F3F0EA"/>
        <SolidColorBrush x:Key="Ink" Color="#232323"/>
        <SolidColorBrush x:Key="MutedInk" Color="#6C6861"/>
        <SolidColorBrush x:Key="Panel" Color="#FFFCF7"/>
        <SolidColorBrush x:Key="Input" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Line" Color="#D8D0C4"/>
        <SolidColorBrush x:Key="Accent" Color="#315B7A"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#E2EEF3"/>
        <SolidColorBrush x:Key="Warm" Color="#A95F47"/>
        <SolidColorBrush x:Key="Side" Color="#253137"/>
        <SolidColorBrush x:Key="SideText" Color="#FFF8EC"/>
        <SolidColorBrush x:Key="SideMuted" Color="#B8C4C9"/>
        <SolidColorBrush x:Key="SideDim" Color="#8FA0A7"/>
        <SolidColorBrush x:Key="Ghost" Color="#E9E2D8"/>
        <SolidColorBrush x:Key="MessageHover" Color="#E9E2D8"/>
        <SolidColorBrush x:Key="WorkspaceHover" Color="#36434A"/>
        <SolidColorBrush x:Key="WorkspaceSelected" Color="#E6F0F4"/>
        <SolidColorBrush x:Key="WorkspaceSelectedText" Color="#1E2E35"/>
        <SolidColorBrush x:Key="FileHoverBorder" Color="#9FAFB8"/>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource Ghost}"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#556167"/>
            <Setter Property="Foreground" Value="{DynamicResource SideText}"/>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SideMuted}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WorkspaceHover}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SideText}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Warm}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Warm}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Shell"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="6,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Background="{DynamicResource Line}"
                                Opacity="0.9"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="Background" Value="{DynamicResource Input}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="SingleLineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="WorkspaceItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource SideText}"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="WorkspaceItem_PreviewMouseRightButtonDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Shell" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="{DynamicResource WorkspaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="{DynamicResource WorkspaceSelected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource WorkspaceSelectedText}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="FileItem_PreviewMouseRightButtonDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Shell" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="BorderBrush" Value="{DynamicResource FileHoverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter TargetName="Shell" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="CustomTitleBar"
                Grid.Row="0"
                Background="{DynamicResource Side}"
                BorderBrush="{DynamicResource Line}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/ThoughtFlowIcon.ico" Width="18" Height="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Thought Flow"
                               Foreground="{DynamicResource SideText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeWindowButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeWindowButton_Click"
                            ToolTip="Minimize"
                            AutomationProperties.Name="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Canvas Width="16" Height="16">
                            <Line X1="4" Y1="11" X2="12" Y2="11"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>
                    <Button x:Name="MaximizeWindowButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Margin="2,0,0,0"
                            Click="MaximizeWindowButton_Click"
                            ToolTip="Maximize"
                            AutomationProperties.Name="Maximize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid Width="16" Height="16">
                            <Canvas x:Name="MaximizeWindowIcon" Width="16" Height="16">
                                <Rectangle Canvas.Left="3" Canvas.Top="3"
                                           Width="10" Height="10"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.6"/>
                            </Canvas>
                            <Canvas x:Name="RestoreWindowIcon" Width="16" Height="16" Visibility="Collapsed">
                                <Rectangle Canvas.Left="5" Canvas.Top="3"
                                           Width="8" Height="8"
                                           RadiusX="1" RadiusY="1"
                                           Fill="Transparent"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.4"/>
                                <Rectangle Canvas.Left="3" Canvas.Top="5"
                                           Width="8" Height="8"
                                           RadiusX="1" RadiusY="1"
                                           Fill="{DynamicResource Side}"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1.4"/>
                            </Canvas>
                        </Grid>
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Margin="2,0,0,0"
                            Click="CloseWindowButton_Click"
                            ToolTip="Close"
                            AutomationProperties.Name="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Canvas Width="16" Height="16">
                            <Line X1="4" Y1="4" X2="12" Y2="12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                            <Line X1="12" Y1="4" X2="4" Y2="12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="245"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Side}" Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="Thought Flow" Foreground="{DynamicResource SideText}" FontSize="23" FontWeight="Bold"/>
                    <TextBlock x:Name="AppSubtitleText" Text="workspaces, files, message-text" Foreground="{DynamicResource SideMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="SaveStatusText" Text="Saved" Foreground="{DynamicResource SideMuted}" FontSize="12"/>
                            <TextBlock x:Name="StoragePathText" Foreground="{DynamicResource SideDim}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                        <Button x:Name="SettingsButton"
                                Grid.Column="1"
                                Style="{StaticResource SettingsButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="SettingsButton_Click"
                                ToolTip="Settings"
                                AutomationProperties.Name="Settings">
                            <Image Source="Assets/GearIcon.png"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"/>
                        </Button>
                    </Grid>
                    <StackPanel x:Name="UndoDeleteList" Margin="0,0,0,14"/>
                    <TextBlock x:Name="NewWorkspaceLabel" Text="New workspace" Foreground="{DynamicResource SideMuted}" FontSize="12" FontWeight="SemiBold"/>
                    <Grid Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewChannelBox"
                                 Style="{StaticResource SingleLineTextBox}"
                                 MinHeight="34"
                                 KeyDown="NewChannelBox_KeyDown"/>
                        <Button Grid.Column="1" Content="+" Margin="8,0,0,0" Click="AddChannelButton_Click"/>
                    </Grid>
                </StackPanel>

                <ListBox x:Name="ChannelsList"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource WorkspaceItemStyle}"
                         SelectionChanged="ChannelsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="15"/>
                                <TextBlock Text="{Binding CountText}" FontSize="12" Opacity="0.75" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="ChannelTitle" FontSize="29" FontWeight="Bold" Foreground="{DynamicResource Ink}"/>
                    <TextBlock x:Name="ChannelSubtitle" Foreground="{DynamicResource MutedInk}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="DuplicateMessageButton" Content="Duplicate msg" Style="{StaticResource GhostButton}" Width="118" Margin="0,0,8,0" Click="DuplicateButton_Click"/>
                    <Button x:Name="DeleteWorkspaceButton" Content="Delete workspace" Background="{DynamicResource Warm}" Width="166" Click="DeleteChannelButton_Click"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock x:Name="FilesLabel" Text="Files" Foreground="{DynamicResource MutedInk}" FontSize="12" FontWeight="SemiBold"/>
                            <Button x:Name="DeleteFileButton" Content="Delete file" DockPanel.Dock="Right" Width="116" MinHeight="28" Padding="8,4" Background="{DynamicResource Warm}" Click="DeleteFileButton_Click"/>
                        </DockPanel>
                        <ListBox x:Name="FilesList"
                                 MinHeight="48"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource FileItemStyle}"
                                 SelectionChanged="FilesList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="11" Foreground="{DynamicResource MutedInk}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock x:Name="NewFileLabel" Text="New file" Foreground="{DynamicResource MutedInk}" FontSize="12" FontWeight="SemiBold"/>
                        <Grid Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NewFileBox"
                                     Style="{StaticResource SingleLineTextBox}"
                                     MinHeight="34"
                                     KeyDown="NewFileBox_KeyDown"/>
                            <Button Grid.Column="1" Content="+" Margin="8,0,0,0" Click="AddFileButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource SingleLineTextBox}"
                         MinHeight="38"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Grid.Column="1" x:Name="SearchStatsText" Foreground="{DynamicResource MutedInk}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <Border Grid.Row="3" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="0">
                <Grid x:Name="MessageStreamHost" MouseLeave="MessageStreamHost_MouseLeave">
                    <RichTextBox x:Name="MessageStreamBox"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="{DynamicResource Input}"
                                 Foreground="{DynamicResource Ink}"
                                 FontSize="15"
                                 Padding="18"
                                 VerticalScrollBarVisibility="Auto"
                                 MouseMove="MessageStreamBox_MouseMove"
                                 PreviewMouseRightButtonDown="MessageStreamBox_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="MessageStreamBox_ContextMenuOpening"
                                 MouseLeftButtonUp="MessageStreamBox_MouseLeftButtonUp">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="StreamEditMenuItem" Header="Edit" Click="EditMessageContextMenuItem_Click"/>
                                <MenuItem x:Name="StreamDuplicateMenuItem" Header="Duplicate" Click="DuplicateMessageContextMenuItem_Click"/>
                                <MenuItem x:Name="StreamCopyMenuItem" Header="Copy" Click="CopyMessageContextMenuItem_Click"/>
                                <Separator/>
                                <MenuItem x:Name="StreamDeleteMenuItem" Header="Delete" Click="DeleteMessageContextMenuItem_Click"/>
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                        <FlowDocument PagePadding="0"/>
                    </RichTextBox>
                    <Button x:Name="MessageActionsButton"
                            Content="..."
                            Width="34"
                            MinHeight="28"
                            Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,14,0"
                            Visibility="Collapsed"
                            Style="{StaticResource GhostButton}"
                            Click="MessageActionsButton_Click"
                            ToolTip="Message actions">
                        <Button.ContextMenu>
                            <ContextMenu Opened="MessageActionsContextMenu_Opened" Closed="MessageActionsContextMenu_Closed">
                                <MenuItem x:Name="HoverEditMenuItem" Header="Edit" Click="EditHoveredMessageMenuItem_Click"/>
                                <MenuItem x:Name="HoverDuplicateMenuItem" Header="Duplicate" Click="DuplicateHoveredMessageMenuItem_Click"/>
                                <MenuItem x:Name="HoverCopyMenuItem" Header="Copy" Click="CopyHoveredMessageMenuItem_Click"/>
                                <Separator/>
                                <MenuItem x:Name="HoverDeleteMenuItem" Header="Delete" Click="DeleteHoveredMessageMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ComposerBox"
                             MinHeight="78"
                             MaxHeight="150"
                             VerticalAlignment="Stretch"
                             KeyDown="ComposerBox_KeyDown"/>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <Button x:Name="SendButton" Content="Send" Width="118" Click="SendButton_Click"/>
                        <TextBlock x:Name="ComposerShortcutText" Text="Ctrl+Enter" Foreground="{DynamicResource MutedInk}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1,0,0,0" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock x:Name="EditorTitleText" Text="Message editor" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Ink}"/>
                    <TextBlock x:Name="EditorStateText" Foreground="{DynamicResource MutedInk}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock x:Name="EditorHint" Grid.Row="1" Foreground="{DynamicResource MutedInk}" Margin="0,6,0,18" TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <Grid>
                        <Button x:Name="MarkButton" Width="112" Style="{StaticResource GhostButton}" Click="MarkButton_Click" ToolTip="Mark selected text with the chosen color">
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="MarkColorSwatch"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="3"
                                        Background="#D8B4FE"
                                        BorderBrush="#6D28D9"
                                        BorderThickness="1"
                                        ToolTip="Choose marker color"
                                        PreviewMouseLeftButtonDown="MarkColorSwatch_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="MarkColorSwatch_PreviewMouseLeftButtonUp"/>
                                <TextBlock x:Name="MarkButtonText" Grid.Column="1" Text="Mark" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Popup x:Name="MarkColorPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=MarkButton}" StaysOpen="False">
                            <Border Background="{DynamicResource Input}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="8">
                                <WrapPanel Width="132">
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#D8B4FE" Tag="#D8B4FE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#BFDBFE" Tag="#BFDBFE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#BBF7D0" Tag="#BBF7D0" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FEF08A" Tag="#FEF08A" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FED7AA" Tag="#FED7AA" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#FBCFE8" Tag="#FBCFE8" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#CFFAFE" Tag="#CFFAFE" Click="MarkColorButton_Click"/>
                                    <Button Width="28" Height="28" MinHeight="28" Margin="2" Padding="0" Background="#E5E7EB" Tag="#E5E7EB" Click="MarkColorButton_Click"/>
                                </WrapPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button x:Name="ClearMarkButton" Content="Clear" Width="92" Margin="8,0,0,0" Style="{StaticResource GhostButton}" Click="ClearMarkButton_Click" ToolTip="Clear selected text marker"/>
                </StackPanel>
                <RichTextBox x:Name="EditorBox"
                             Grid.Row="3"
                             FontSize="15"
                             IsEnabled="False"
                             TextChanged="EditorBox_TextChanged"
                             BorderBrush="{DynamicResource Line}"
                             BorderThickness="1"
                             Padding="10"
                             Background="{DynamicResource Input}"
                             Foreground="{DynamicResource Ink}"
                             VerticalScrollBarVisibility="Auto">
                    <FlowDocument PagePadding="0"/>
                </RichTextBox>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="CopyButton" Content="Copy" Style="{StaticResource GhostButton}" Width="112" Margin="0,0,10,0" Click="CopyButton_Click"/>
                    <Button x:Name="DeleteMessageButton" Content="Delete" Background="{DynamicResource Warm}" Width="92" Margin="0,0,10,0" Click="DeleteButton_Click"/>
                    <Button x:Name="SaveButton" Content="Save" Width="104" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>

